# ─── Python (py/) ──────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.egg-info/
py/dist/
py/build/
py/.env
py/.venv/
py/models/
py/Neo4_data/
py/data/workitems_cache.json
py/projects.json
py/_debug_*.py
py/_explore_*.py
py/_test_*.py
py/.mypy_cache/
py/.ruff_cache/
py/.pytest_cache/

# ─── .NET (dotnet/) ─────────────────────────────────────────────────────────

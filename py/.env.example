# Ollama LLM (local)
OLLAMA_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3
LLM_TEMPERATURE=0.0

# Neo4j (optional – only needed when using Neo4jGraphStore)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=bladed01

# Embedding model (sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Mono-repo root to index
REPO_ROOT=.

# File extensions to index (comma-separated)
INDEX_EXTENSIONS=.py,.cpp,.h,.hpp,.cs

# Directories to skip (comma-separated)
SKIP_DIRS=.git,node_modules,__pycache__,.venv,bin,obj,Debug,Release,build,dist

# Persist the graph index to disk (pickle)
GRAPH_CACHE_PATH=data/code_graph.pkl
